# LLM API config (supports any LLM API in OpenAI SDK format)
# Recommended: Alibaba Bailian platform's qwen-plus model: https://bailian.console.aliyun.com/
# Note: usage can be heavy; try a simulation with fewer than 40 rounds first
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus
# Optional: smaller/cheaper model used by Graphiti for extraction (defaults to LLM_MODEL_NAME)
# LLM_SMALL_MODEL_NAME=qwen-turbo

# ===== Knowledge graph: Graphiti + FalkorDB (self-hosted, replaces Zep Cloud) =====
# FalkorDB connection. In docker-compose these are overridden to point at the
# `falkordb` service automatically; for local (non-docker) runs FalkorDB defaults
# to localhost:6379 (start it via `docker run -p 6379:6379 falkordb/falkordb`).
GRAPH_DB_HOST=localhost
GRAPH_DB_PORT=6379
# GRAPH_DB_USERNAME=
# GRAPH_DB_PASSWORD=
GRAPH_DB_NAME=mirofish

# Embeddings (Graphiti requires a vector embedder; defaults reuse the LLM creds).
# IMPORTANT: EMBEDDER_DIM must match the embedding model's output dimension.
#   - OpenAI text-embedding-3-small => 1536
#   - Alibaba text-embedding-v3     => 1024
# EMBEDDER_API_KEY=your_api_key_here
# EMBEDDER_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDER_MODEL_NAME=text-embedding-3-small
EMBEDDER_DIM=1536

# ===== Boost LLM config (optional) =====
# Note: if you don't use the boost config, do not include the entries below in your env file
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here

# ===== Flask config =====
# Required in production (FLASK_DEBUG=false): the backend refuses to start without it.
# Use a long, random value, e.g. `python -c "import secrets; print(secrets.token_hex(32))"`
SECRET_KEY=your_secret_key_here
